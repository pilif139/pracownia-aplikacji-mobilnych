<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/header"
        android:text="Wizyta u weterynarza" />

    <EditText
        android:id="@+id/wlasciciel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="text"
        android:hint="Imię i nazwisko właściciela" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gatunek" />

    <ListView
        android:id="@+id/gatunki"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ile ma lat? " />
        <TextView
            android:id="@+id/wiek"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0" />
        <SeekBar
            android:id="@+id/ile_lat"
            android:min="0"
            android:max="20"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:thumbTint="#02D8E9"/>
    </LinearLayout>

    <EditText
        android:id="@+id/cel_wizyty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ems="10"
        android:inputType="text"
        android:hint="Cel wizyty" />

    <EditText
        android:id="@+id/czas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="time"
        android:text="16:00"
        />

    <Button
        android:id="@+id/button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="OK" />
</LinearLayout>